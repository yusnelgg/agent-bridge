# ── Configuración de agent-bridge ─────────────────────────

identity: "frontend"                # Tu identidad en la red
listen_addr: "127.0.0.1:9090"       # Puerto para API HTTP local
nats_url: "nats://127.0.0.1:4222"   # URL del servidor NATS
nats_port: 4222                     # Puerto NATS
db_path: "agent-bridge.db"          # Base de datos SQLite local
server_mode: true                   # true = inicia NATS embebido
mcp_server: false                   # true = expone MCP (para Claude Code)
